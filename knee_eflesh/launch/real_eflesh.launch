<launch>
  <arg name="cfg" default="rsl.yaml"/>

  <node
    pkg="dynasense"
    type="udp_sensor_node.py"
    name="dynasense_udp_receiver"
    output="screen"
    >
    <rosparam command="load" file="$(find dynasense)/knee_eflesh/config/udp_sensor_params.yaml" />
  </node>

  <node
    pkg="dynasense"
    type="knee_contact_force_visualizer.py"
    name="knee_contact_force_visualizer"
    output="screen"
    >
    <param name="input_topic" value="/dynasense/knee_vis" />
    <param name="target_frame" value="odom" />
  </node>

</launch>
